{
    "include": [
        "main.py",
        "gui",
        "modules",
        "core"
    ],
    "exclude": [
        "**/__pycache__",
        "**/*.pyc"
    ],
    "ignore": [],
    "defineConstant": {},
    "stubPath": "",
    "venvPath": ".",
    "venv": "venv",
    "pythonVersion": "3.11",
    "pythonPlatform": "Windows",
    "executionEnvironments": [
        {
            "root": "."
        }
    ],
    "typeCheckingMode": "off",
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none",
    "reportUnusedImport": "none",
    "reportUnusedVariable": "none"
}
